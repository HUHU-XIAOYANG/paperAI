# Agent Swarm Writing System - Environment Configuration Example
# Copy this file to .env for local development

# Development Server Configuration
VITE_DEV_PORT=1420
VITE_HMR_PORT=1421

# Tauri Development Host (optional, for network development)
# TAURI_DEV_HOST=0.0.0.0

# Build Configuration
# VITE_BUILD_SOURCEMAP=false
# VITE_BUILD_MINIFY=true

# Application Configuration
VITE_APP_NAME="Agent Swarm Writing System"
VITE_APP_VERSION="0.1.0"

# API Configuration (for future AI service integration)
# VITE_AI_API_URL=
# VITE_AI_API_KEY=

# Feature Flags
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_LOGGING=true
