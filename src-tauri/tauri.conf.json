{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Swarm Writing System",
  "version": "0.1.0",
  "identifier": "com.agentswarm.writingsystem",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Swarm Writing System",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../prompts/*"],
    "copyright": "Copyright © 2024 Agent Swarm Writing System",
    "category": "Productivity",
    "shortDescription": "Multi-agent collaborative academic paper writing system",
    "longDescription": "Agent Swarm Writing System is a lightweight multi-agent collaboration program for academic paper drafting and review processes.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
